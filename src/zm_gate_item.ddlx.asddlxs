  @EndUserText.label: 'Currency'
  waers;
  @UI.lineItem: [{ position : 140}]
  @UI.identification: [{ position: 140, label: 'PO Rate' }]
  @EndUserText.label: 'PO Rate'
  netpr;
  @UI.lineItem: [{ position : 150}]
  @UI.identification: [{ position: 150, label: 'Total Amt' }]
  @EndUserText.label: 'Total Amt'
  dmbtr;
  @UI.lineItem: [{ position : 160}]
