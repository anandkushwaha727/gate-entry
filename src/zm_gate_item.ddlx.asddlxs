  @EndUserText.label: 'Open Qty'
  opqty;
  @UI.lineItem: [{ position : 110}]
  @UI.identification: [{ position: 110, label: 'Inv Qty' }]
  @EndUserText.label: 'Inv Qty'
  menge;
  @UI.lineItem: [{ position : 120}]
