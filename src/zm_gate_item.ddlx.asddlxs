@Metadata.layer: #CUSTOMER
@UI:{headerInfo: { typeName: 'Item Detail',
                   typeNamePlural: 'Item Details',
                   title: { type: #STANDARD, value: 'ebeln' },
                   description: { type: #STANDARD, value: 'maktx' } } }
annotate entity ZC_GATE_ITEM with
{
  @UI.facet: [
        {
          label: 'Item Details',
          id: 'ItemInfo',
          type: #COLLECTION,
          position: 10
        },
        {
          label: 'Gate Entry',
          id: 'Gate',
          type: #IDENTIFICATION_REFERENCE,
          purpose: #STANDARD,
          parentId: 'ItemInfo',
          position: 10
        }

    ]
    
  @UI.lineItem: [{ position : 10, criticality: 'criticality', criticalityRepresentation: #WITH_ICON }]
  @UI.identification: [{ position : 10, criticality: 'criticality', criticalityRepresentation: #WITH_ICON, label :'ID' }]
  @UI.hidden: true
  @EndUserText.label: 'ID'
  xicon;
  @UI.lineItem: [{ position : 20 }]
  @UI.identification: [{ position : 20, label : 'Message' }]
  @UI.hidden: true
  @EndUserText.label: 'Message'
  ztext;
  @UI.lineItem: [{ position : 30 }]
  @UI.identification: [{ position : 30, label : 'Gate Entry' }]
  @UI.hidden: true
  @EndUserText.label: 'Gate Entry'
  zrgno;
